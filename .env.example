# Angel One SmartAPI Credentials
# Get these from https://smartapi.angelone.in/

# Your API Key (from Angel One Smart API dashboard)
ANGEL_API_KEY=your_api_key_here

# Your Angel One Client ID (trading account ID)
ANGEL_CLIENT_ID=your_client_id_here

# Your Angel One Password (MPIN or trading password)
ANGEL_PASSWORD=your_password_here

# Your TOTP Secret Key (for 2FA authentication)
# This is the secret key used to generate TOTP codes
# You can get this from your authenticator app setup or Angel One
ANGEL_TOTP=your_totp_secret_here
